Content-Type: application/json

{
  "patientId": 1,
  "type": "Control Diabetológico",
  "scheduledAt": "2026-07-05T09:00:00",
  "location": "Consultorio 3 — Endocrinología",
  "notes": "Traer resultados de glucosa en ayunas",
  "requirements": ["Ayuno de 8 horas", "Traer carnet de vacunación"]
}

