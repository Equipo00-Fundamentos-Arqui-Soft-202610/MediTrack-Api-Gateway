      "stockCount": 30,
      "stockAlertThreshold": 5,
      "doseSchedules": [
        { "scheduledTime": "21:00:00" }
      ]
    },
    {
      "catalogId": 3,
      "dose": "50mg",
      "frequencyHours": 24,
      "startDate": "2026-06-24T00:00:00",
      "endDate": "2026-12-24T00:00:00",
      "stockCount": 30,
      "stockAlertThreshold": 5,
      "doseSchedules": [
        { "scheduledTime": "08:00:00" }
      ]
    }
  ]
}

### [Appointment 1/5] Cita control diabetológico — Paciente 1 (Carlos)
